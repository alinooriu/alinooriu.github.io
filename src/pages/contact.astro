---
import '../styles/contact.css';
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>ارتباط با ما | گالری لومیر</title>
</head>
<body>

    <div class="page-wrapper">
        <div class="background-elements">
            <div class="bg-sphere bg-sphere-1"></div>
            <div class="bg-sphere bg-sphere-2"></div>
            <div class="bg-sphere bg-sphere-3"></div>
        </div>

        <main class="contact-card">
            <div class="foreground-sphere fg-sphere-1"></div>
            <div class="foreground-sphere fg-sphere-2"></div>

            <h1 class="form-title">ارتباط با ما</h1>
            <p class="form-subtitle">جهت دریافت کاتالوگ و مشاوره خرید، مشخصات خود را وارد کنید.</p>

            <form id="whatsappForm" class="luxury-form">
                <div class="input-group">
                    <label for="fullName">نام و نام خانوادگی</label>
                    <input type="text" id="fullName" required placeholder="مثال: علی نوری" autocomplete="off" />
                </div>

                <div class="input-group">
                    <label for="phoneNumber">شماره تماس</label>
                    <input type="tel" id="phoneNumber" required placeholder="09123456789" autocomplete="off" dir="ltr" />
                </div>

                <button type="submit" class="btn-submit">
                    <span>ثبت درخواست مشاوره اختصاصی</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4Z"/>
                    </svg>
                </button>
            </form>
        </main>
    </div>

    <script src="../scripts/form-handler.js"></script>
</body>
</html>